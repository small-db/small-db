<mxfile host="app.diagrams.net">
  <diagram name="Transaction Model Evolution" id="txn-model-evolution">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Evolution of small-db's transaction model"
                style="text;html=1;align=center;fontSize=22;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1420" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="subtitle" value="Each arrow has a verb. Each block has a tag. Anomalies drive solutions; solutions establish invariants; new natures emerge and produce new anomalies."
                style="text;html=1;align=center;fontSize=13;fontStyle=2;fontColor=#444"
                vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1420" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="legend" value="&lt;b&gt;Tag legend:&lt;/b&gt; &amp;nbsp;&amp;nbsp; &lt;span style='background:#dae8fc;padding:2px 6px;border:1px solid #6c8ebf;'&gt;START&lt;/span&gt; &amp;nbsp; &lt;span style='background:#f8cecc;padding:2px 6px;border:1px solid #b85450;border-radius:10px;'&gt;ANOMALY&lt;/span&gt; &amp;nbsp; &lt;span style='background:#dae8fc;padding:2px 6px;border:1px solid #6c8ebf;'&gt;SOLUTION&lt;/span&gt; &amp;nbsp; &lt;span style='background:#d5e8d4;padding:2px 6px;border:1px solid #82b366;'&gt;INVARIANT&lt;/span&gt; &amp;nbsp; &lt;span style='background:#f5f5f5;padding:2px 6px;border:1px solid #999;'&gt;NATURE&lt;/span&gt; &amp;nbsp; &lt;span style='background:#fff2cc;padding:2px 6px;border:1px solid #d6b656;border-radius:10px;'&gt;HINT&lt;/span&gt; &amp;nbsp; &lt;span style='background:#ffe6cc;padding:2px 6px;border:1px solid #d79b00;'&gt;CANDIDATE&lt;/span&gt; &amp;nbsp; &lt;span style='background:#f8cecc;padding:2px 6px;border:1px solid #b85450;'&gt;ISSUE&lt;/span&gt; &amp;nbsp; &lt;span style='background:#d5e8d4;padding:2px 6px;border:2px solid #82b366;'&gt;FINAL SOLUTION&lt;/span&gt;"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;align=left;fontSize=11"
                vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="1380" height="44" as="geometry"/>
        </mxCell>

        <mxCell id="start" value="&lt;b&gt;[START]&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Distributed KV, no concurrency control&lt;/b&gt;&lt;br&gt;Single value per key; writes overwrite in place. No isolation — a read interleaved with a multi-key update sees a partial state."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="160" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="anom1" value="&lt;b&gt;[ANOMALY]&lt;/b&gt;&lt;br&gt;&lt;b&gt;A reader sees a partial / mid-write state of the database&lt;/b&gt;&lt;br&gt;Application invariants appear violated even though every write succeeds individually."
                style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="280" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_start_anom1" value="produces" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="start" target="anom1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="sol1" value="&lt;b&gt;[SOLUTION]&lt;/b&gt;&lt;br&gt;&lt;b&gt;MVCC: versioned writes, snapshot reads&lt;/b&gt;&lt;br&gt;Each write is a new version tagged with ts. Reads pick the newest version ≤ snapshot_ts per row."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="405" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_anom1_sol1" value="solved by" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="anom1" target="sol1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="inv1" value="&lt;b&gt;[INVARIANT]&lt;/b&gt;&lt;br&gt;Per-row visibility = lex-largest version_ts ≤ snapshot_ts."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="1140" y="415" width="320" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="arr_sol1_inv1" value="establishes" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#82b366;fontSize=12;fontStyle=2;fontColor=#557f3f" edge="1" parent="1" source="sol1" target="inv1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="anom2" value="&lt;b&gt;[ANOMALY]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Lost update — concurrent RMW on the same row&lt;/b&gt;&lt;br&gt;Two writers read the same pre-image, both compute, both write. One's effect vanishes."
                style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="525" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_sol1_anom2" value="leaves open" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="sol1" target="anom2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="sol2" value="&lt;b&gt;[SOLUTION]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Per-row exclusive lock + read-latest under the lock&lt;/b&gt;&lt;br&gt;A writer locks the row, reads the latest committed value, computes, writes, releases."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="650" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_anom2_sol2" value="solved by" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="anom2" target="sol2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="inv2" value="&lt;b&gt;[INVARIANT]&lt;/b&gt;&lt;br&gt;At most one writer in RMW on a given row at a time."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="1140" y="660" width="320" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="arr_sol2_inv2" value="establishes" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#82b366;fontSize=12;fontStyle=2;fontColor=#557f3f" edge="1" parent="1" source="sol2" target="inv2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="anom3" value="&lt;b&gt;[ANOMALY]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Read skew across statements&lt;/b&gt;&lt;br&gt;A transfer is two UPDATEs at two different ts; a SELECT can land between and see one half only."
                style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="770" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_sol2_anom3" value="leaves open" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="sol2" target="anom3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="sol3" value="&lt;b&gt;[SOLUTION]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Multi-statement transactions: deferred writes, shared commit_ts&lt;/b&gt;&lt;br&gt;BEGIN buffers writes; COMMIT picks one ts and dispatches all at that ts."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="895" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_anom3_sol3" value="solved by" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="anom3" target="sol3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="inv3" value="&lt;b&gt;[INVARIANT]&lt;/b&gt;&lt;br&gt;All writes of one transaction share one commit_ts (atomicity)."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="1140" y="905" width="320" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="arr_sol3_inv3" value="establishes" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#82b366;fontSize=12;fontStyle=2;fontColor=#557f3f" edge="1" parent="1" source="sol3" target="inv3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="nature" value="&lt;b&gt;[NATURE]&lt;/b&gt;&lt;br&gt;&lt;b&gt;commit_ts is picked at the coordinator&lt;/b&gt;&lt;br&gt;It doesn't reflect what the storage layer has observed. A causal dependency at the row owner (read-latest under the lock) does NOT advance the coordinator's commit_ts."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="1020" width="640" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="arr_sol3_nature" value="introduces" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="sol3" target="nature">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="anom4" value="&lt;b&gt;[ANOMALY]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Shadowed write&lt;/b&gt;&lt;br&gt;A chronologically-later commit lands at a smaller version_ts and is invisible to MVCC reads."
                style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="430" y="1150" width="640" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_nature_anom4" value="produces" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="nature" target="anom4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="hint" value="&lt;b&gt;[HINT]&lt;/b&gt;&lt;br&gt;&lt;b&gt;commit_ts must be pushable past observed dependencies&lt;/b&gt;&lt;br&gt;If a write composes on top of a value at ts=X, its commit_ts must end up &gt; X."
                style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="370" y="1270" width="760" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_anom4_hint" value="implies" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="anom4" target="hint">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="candA" value="&lt;b&gt;[CANDIDATE]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Per-row version_ts bump&lt;/b&gt;&lt;br&gt;At write time, raise version_ts to max(caller_ts, latest_for_pk + 1). Per-row, decided by the lock holder."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="160" y="1410" width="380" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="arr_hint_candA" value="candidate" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666;exitX=0.25;exitY=1;exitDx=0;exitDy=0" edge="1" parent="1" source="hint" target="candA">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="issueA" value="&lt;b&gt;[ISSUE]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Breaks the atomicity invariant&lt;/b&gt;&lt;br&gt;Per-row bump fires independently per row. Writes of one tx end up at different version_ts."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="160" y="1555" width="380" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_candA_issueA" value="blocked by" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="candA" target="issueA">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="candB" value="&lt;b&gt;[CANDIDATE]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Rewrite all rows of the tx on push&lt;/b&gt;&lt;br&gt;Pick a single commit_ts for the whole tx at COMMIT, scan past every touched row's latest, and rewrite each at the new ts."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="960" y="1410" width="380" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="arr_hint_candB" value="candidate" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666;exitX=0.75;exitY=1;exitDx=0;exitDy=0" edge="1" parent="1" source="hint" target="candB">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="issueB" value="&lt;b&gt;[ISSUE]&lt;/b&gt;&lt;br&gt;&lt;b&gt;O(N) rewrites at commit&lt;/b&gt;&lt;br&gt;Every flushed row must be re-Put on push. Commit cost grows with the tx's write set."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="960" y="1555" width="380" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_candB_issueB" value="blocked by" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666" edge="1" parent="1" source="candB" target="issueB">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="finalSol" value="&lt;b&gt;[FINAL SOLUTION]&lt;/b&gt;&lt;br&gt;&lt;b&gt;Intents + txn record&lt;/b&gt;&lt;br&gt;Each row write lays down an intent { value, txn_id } pointing to a shared txn record.&lt;br&gt;The txn record holds { status, commit_ts }; visibility decisions consult it.&lt;br&gt;COMMIT and PUSH are single atomic updates of the txn record. Resolution is lazy."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2.5;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="370" y="1730" width="760" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="arr_issueA_final" value="motivates" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="issueA" target="finalSol">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arr_issueB_final" value="motivates" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444;fontSize=12;fontStyle=2;fontColor=#666;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="issueB" target="finalSol">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="finalInv1" value="&lt;b&gt;[INVARIANT]&lt;/b&gt;&lt;br&gt;Visibility decided by a single shared txn record, not by the row entry alone. All N intents flip to visible together via one record write."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="160" y="1895" width="560" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="finalInv2" value="&lt;b&gt;[INVARIANT]&lt;/b&gt;&lt;br&gt;COMMIT and PUSH are O(1) record updates; no row rewriting on the hot path. Atomicity is preserved: all of T's intents share one record."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="1895" width="560" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="arr_final_inv1" value="establishes" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#82b366;fontSize=12;fontStyle=2;fontColor=#557f3f" edge="1" parent="1" source="finalSol" target="finalInv1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arr_final_inv2" value="establishes" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#82b366;fontSize=12;fontStyle=2;fontColor=#557f3f" edge="1" parent="1" source="finalSol" target="finalInv2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="footer" value="Read top to bottom. Every arrow has a verb (produces / solved by / establishes / leaves open / introduces / implies / motivates) that names the relationship between blocks. Solutions establish invariants but also introduce new natures, which produce new anomalies. The chain converges only when the final design satisfies every invariant accumulated along the way."
                style="text;html=1;align=center;fontSize=12;fontStyle=2;fontColor=#444"
                vertex="1" parent="1">
          <mxGeometry x="40" y="2030" width="1420" height="60" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
