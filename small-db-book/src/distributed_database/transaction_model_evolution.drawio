<mxfile host="app.diagrams.net">
  <diagram name="Transaction Model Evolution" id="txn-model-evolution">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1750" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Evolution of small-db's transaction model"
                style="text;html=1;align=center;fontSize=22;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1420" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="subtitle" value="Each decision introduces invariants. Subsequent decisions either build on them or are constrained by them."
                style="text;html=1;align=center;fontSize=14;fontStyle=2;fontColor=#444444"
                vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="1420" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="leftHeader" value="DECISIONS"
                style="text;html=1;align=center;fontSize=14;fontStyle=1;fontColor=#666666"
                vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="660" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="rightHeader" value="INVARIANTS &amp; REQUIREMENTS"
                style="text;html=1;align=center;fontSize=14;fontStyle=1;fontColor=#666666"
                vertex="1" parent="1">
          <mxGeometry x="780" y="100" width="680" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="stage0" value="&lt;b&gt;Stage 0 — Distributed KV, no concurrency control&lt;/b&gt;&lt;br&gt;&lt;br&gt;Writes hit storage immediately at wall-clock ts.&lt;br&gt;&lt;font color='#b85450'&gt;No invariants. Anomalies everywhere.&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;fontSize=13"
                vertex="1" parent="1">
          <mxGeometry x="40" y="155" width="660" height="95" as="geometry"/>
        </mxCell>

        <mxCell id="t01prob" value="&lt;b&gt;Problem.&lt;/b&gt; Readers must wait for writers; concurrent writes overwrite each other."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="80" y="266" width="270" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="t01ins" value="&lt;b&gt;Insight.&lt;/b&gt; A coherent past view is enough for readers. Make writes append new versions."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="390" y="266" width="290" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="arr01" style="endArrow=classic;html=1;rounded=0;strokeWidth=2.5;strokeColor=#444444" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="250" as="sourcePoint"/>
            <mxPoint x="370" y="335" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="stage1" value="&lt;b&gt;Stage 1 — MVCC&lt;/b&gt;&lt;br&gt;&lt;br&gt;Each write produces a new version tagged with ts.&lt;br&gt;Reads filter by snapshot_ts and pick the latest visible per row.&lt;br&gt;&lt;br&gt;&lt;b&gt;&lt;font color='#82b366'&gt;introduces I1, I2&lt;/font&gt;&lt;/b&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;fontSize=13"
                vertex="1" parent="1">
          <mxGeometry x="40" y="335" width="660" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="invI1" value="&lt;b&gt;I1.&lt;/b&gt; Each write produces a new immutable version. Rows are never overwritten.&lt;br&gt;&lt;font size='1' color='#666'&gt;— a per-row append-only chain of versions&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="335" width="680" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="invI2" value="&lt;b&gt;I2.&lt;/b&gt; Read at snapshot_ts returns the largest version_ts ≤ snapshot_ts (per row).&lt;br&gt;&lt;font size='1' color='#666'&gt;— the &quot;lex-largest visible&quot; rule&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="395" width="680" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="t12prob" value="&lt;b&gt;Problem.&lt;/b&gt; Concurrent writers to the same row both read the pre-image; one's effect lost."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="80" y="466" width="270" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="t12ins" value="&lt;b&gt;Insight.&lt;/b&gt; Writers to one row must serialize so the second sees the first's commit."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="390" y="466" width="290" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="arr12" style="endArrow=classic;html=1;rounded=0;strokeWidth=2.5;strokeColor=#444444" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="450" as="sourcePoint"/>
            <mxPoint x="370" y="535" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="stage2" value="&lt;b&gt;Stage 2 — Per-row exclusive lock + read-latest&lt;/b&gt;&lt;br&gt;&lt;br&gt;A writer locks the row, reads the latest committed value, computes, writes.&lt;br&gt;&lt;font color='#666' face='italic'&gt;builds on I1 (chain is well-defined)&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;&lt;font color='#82b366'&gt;introduces I3, I4&lt;/font&gt;&lt;/b&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;fontSize=13"
                vertex="1" parent="1">
          <mxGeometry x="40" y="535" width="660" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="invI3" value="&lt;b&gt;I3.&lt;/b&gt; At most one writer is in its RMW critical section on a single row at a time.&lt;br&gt;&lt;font size='1' color='#666'&gt;— two concurrent writers serialize&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="535" width="680" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="invI4" value="&lt;b&gt;I4.&lt;/b&gt; Inside the lock, the writer reads the latest committed value (not a snapshot view).&lt;br&gt;&lt;font size='1' color='#666'&gt;— RMW always composes on real current state&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="595" width="680" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="t23prob" value="&lt;b&gt;Problem.&lt;/b&gt; A transfer is two writes at two ts. A reader can land between them."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="80" y="666" width="270" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="t23ins" value="&lt;b&gt;Insight.&lt;/b&gt; One commit_ts must cover all of a transaction's writes."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="390" y="666" width="290" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="arr23" style="endArrow=classic;html=1;rounded=0;strokeWidth=2.5;strokeColor=#444444" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="650" as="sourcePoint"/>
            <mxPoint x="370" y="735" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="stage3" value="&lt;b&gt;Stage 3 — Multi-statement transactions, single commit_ts&lt;/b&gt;&lt;br&gt;&lt;br&gt;BEGIN buffers writes; COMMIT picks one ts and dispatches all at that ts.&lt;br&gt;&lt;font color='#666' face='italic'&gt;builds on I1 (ts-addressable versions), I3 (no interleaving with other writers)&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;&lt;font color='#82b366'&gt;introduces I5&lt;/font&gt;&lt;/b&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=center;fontSize=13"
                vertex="1" parent="1">
          <mxGeometry x="40" y="735" width="660" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="invI5" value="&lt;b&gt;I5.&lt;/b&gt; Every write of one transaction lands at the same version_ts.&lt;br&gt;&lt;font size='1' color='#666'&gt;— a snapshot at any S either sees all of T's writes or none of them&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="755" width="680" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="t34prob" value="&lt;b&gt;Problem.&lt;/b&gt; Two concurrent commits on the same row from different coordinators arrive out of order; the later one is lex-shadowed."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="80" y="866" width="270" height="66" as="geometry"/>
        </mxCell>
        <mxCell id="t34ins" value="&lt;b&gt;Insight.&lt;/b&gt; Observing a value should advance my timestamp past it. The shadowed write happened because that didn't happen."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="390" y="866" width="290" height="66" as="geometry"/>
        </mxCell>
        <mxCell id="arr34" style="endArrow=classic;html=1;rounded=0;strokeWidth=2.5;strokeColor=#444444" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="850" as="sourcePoint"/>
            <mxPoint x="370" y="945" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="stage4" value="&lt;b&gt;Stage 4 — A constraint that fights I5&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;New requirement R1&lt;/b&gt; would close shadowing. But naive enforcement breaks I5:&lt;br&gt;&lt;br&gt;• per-row bumping → each row independently bumped → I5 broken&lt;br&gt;• rewrite all rows on push → preserves I5 → O(N) at commit, hot-path expensive&lt;br&gt;&lt;br&gt;&lt;font color='#666' face='italic'&gt;depends on I5 (must keep), introduces R1 (must add)&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;align=left;fontSize=13;verticalAlign=top;spacingTop=15"
                vertex="1" parent="1">
          <mxGeometry x="40" y="945" width="660" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="reqR1" value="&lt;b&gt;R1.&lt;/b&gt; Each new commit's version_ts on every row it writes must strictly exceed every prior version_ts on that row.&lt;br&gt;&lt;font size='1' color='#666'&gt;— closes shadowed writes; clashes with I5 if enforced per-row&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="945" width="680" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="tensionBox" value="&lt;b&gt;Tension between R1 and I5&lt;/b&gt;&lt;br&gt;&lt;br&gt;Per-row mechanisms can satisfy one but not both.&lt;br&gt;We need a structure that lets a single commit_ts be raised at commit time, &lt;i&gt;without rewriting the rows that already carry the txn's writes.&lt;/i&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="1030" width="680" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="t45prob" value="&lt;b&gt;Tension.&lt;/b&gt; Need (a) commit_ts &gt; all prior version_ts AND (b) one commit_ts per txn. Per-row mechanisms cannot satisfy both."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="80" y="1141" width="270" height="66" as="geometry"/>
        </mxCell>
        <mxCell id="t45ins" value="&lt;b&gt;Insight.&lt;/b&gt; Decouple &quot;the value sitting on this row&quot; from &quot;is this committed, at what ts.&quot; Move the second piece into one shared place."
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="390" y="1141" width="290" height="66" as="geometry"/>
        </mxCell>
        <mxCell id="arr45" style="endArrow=classic;html=1;rounded=0;strokeWidth=2.5;strokeColor=#444444" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="370" y="1125" as="sourcePoint"/>
            <mxPoint x="370" y="1220" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="stage5" value="&lt;b&gt;Stage 5 — Intents + txn record&lt;/b&gt;&lt;br&gt;&lt;br&gt;Each row write lays down an intent &lt;font face='monospace'&gt;{value, txn_id}&lt;/font&gt;;&lt;br&gt;a separate txn record holds &lt;font face='monospace'&gt;{status, commit_ts}&lt;/font&gt;.&lt;br&gt;&lt;br&gt;&lt;b&gt;COMMIT&lt;/b&gt; = one update of the txn record. All N intents flip together.&lt;br&gt;&lt;b&gt;PUSH&lt;/b&gt; = the same one update at a higher commit_ts.&lt;br&gt;&lt;b&gt;RESOLUTION&lt;/b&gt; = lazy rewrite of intents to canonical version entries.&lt;br&gt;&lt;br&gt;&lt;font color='#666' face='italic'&gt;depends on I5 (preserved), R1 (now satisfied)&lt;/font&gt;&lt;br&gt;&lt;b&gt;&lt;font color='#82b366'&gt;introduces I6, I7&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color='#557f3f'&gt;✓ Single commit_ts per txn (atomicity).  ✓ Push past existing versions without rewriting any rows.&lt;/font&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2.5;align=left;fontSize=13;verticalAlign=top;spacingTop=15;spacingLeft=20"
                vertex="1" parent="1">
          <mxGeometry x="40" y="1220" width="660" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="invI6" value="&lt;b&gt;I6.&lt;/b&gt; Each row's effective commit_ts and visibility status are determined by a single shared txn record, not by the row entry alone."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="1220" width="680" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="invI7" value="&lt;b&gt;I7.&lt;/b&gt; Commit and push are single atomic updates of the txn record. Intent resolution is lazy and idempotent."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="1290" width="680" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="composeNote" value="&lt;b&gt;How the invariants compose at Stage 5:&lt;/b&gt;&lt;br&gt;• I6 carries I5: all rows of one txn point to one record → one commit_ts. ✓&lt;br&gt;• I7 carries R1: push raises the txn record's commit_ts in O(1), past prior versions. ✓&lt;br&gt;• I3, I4 still hold (intents are still RMW under a row lock)."
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4f4f4;strokeColor=#999999;dashed=1;align=left;fontSize=12"
                vertex="1" parent="1">
          <mxGeometry x="780" y="1370" width="680" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="footer" value="Read top-to-bottom on the left for the decisions; read top-to-bottom on the right for the invariants each decision adds. Every later stage's text says which earlier invariants it relies on."
                style="text;html=1;align=center;fontSize=13;fontStyle=2;fontColor=#444444"
                vertex="1" parent="1">
          <mxGeometry x="40" y="1530" width="1420" height="40" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
