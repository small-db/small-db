        <mxCell id="t3tick" style="line;strokeColor=#444444;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="510" y="86" width="0" height="12" as="geometry"/>
        </mxCell>
        <mxCell id="t3lblTop" value=".628" style="text;html=1;align=center;fontSize=11;fontStyle=1;fontColor=#444444"
