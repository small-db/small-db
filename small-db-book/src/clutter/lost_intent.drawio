          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="92" as="sourcePoint"/>
            <mxPoint x="1140" y="92" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="timeLabel" value="time" style="text;html=1;fontSize=11;fontColor=#666666"
                vertex="1" parent="1">
          <mxGeometry x="1142" y="86" width="40" height="14" as="geometry"/>
        </mxCell>

        <!-- Tick: .603 T1 BEGIN -->
        <mxCell id="t1tick" style="line;strokeColor=#444444;strokeWidth=2" vertex="1" parent="1">
