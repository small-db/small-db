        </mxCell>
        <mxCell id="t1lblBot" value="T1 BEGIN" style="text;html=1;align=center;fontSize=11;fontColor=#666666"
                vertex="1" parent="1">
          <mxGeometry x="160" y="106" width="80" height="14" as="geometry"/>
        </mxCell>

        <!-- Tick: .627 T1 WriteIntent -->
        <mxCell id="t2tick" style="line;strokeColor=#444444;strokeWidth=2" vertex="1" parent="1">
