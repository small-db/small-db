          <mxGeometry x="460" y="106" width="100" height="14" as="geometry"/>
        </mxCell>

        <!-- Tick: .642 T2 WriteIntent (overwrite) -->
        <mxCell id="t4tick" style="line;strokeColor=#B85450;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="730" y="86" width="0" height="12" as="geometry"/>
        </mxCell>
        <mxCell id="t4lblTop" value=".642" style="text;html=1;align=center;fontSize=11;fontStyle=1;fontColor=#B85450"
                vertex="1" parent="1">
          <mxGeometry x="700" y="62" width="60" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="t4lblBot" value="T2 WriteIntent /2" style="text;html=1;align=center;fontSize=11;fontColor=#B85450"
