        <!-- Tick: .65x reader scan -->
        <mxCell id="t5tick" style="line;strokeColor=#B85450;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="900" y="86" width="0" height="12" as="geometry"/>
        </mxCell>
        <mxCell id="t5lblTop" value=".65x" style="text;html=1;align=center;fontSize=11;fontStyle=1;fontColor=#B85450"
                vertex="1" parent="1">
          <mxGeometry x="870" y="62" width="60" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="t5lblBot" value="Reader (op 15) scans" style="text;html=1;align=center;fontSize=11;fontColor=#B85450"
                vertex="1" parent="1">
          <mxGeometry x="830" y="106" width="140" height="14" as="geometry"/>
        </mxCell>

        <!-- Tick: .652 T2 COMMIT -->
        <mxCell id="t6tick" style="line;strokeColor=#444444;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="1040" y="86" width="0" height="12" as="geometry"/>
        </mxCell>
        <mxCell id="t6lblTop" value=".652" style="text;html=1;align=center;fontSize=11;fontStyle=1;fontColor=#444444"
                vertex="1" parent="1">
          <mxGeometry x="1010" y="62" width="60" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="t6lblBot" value="T2 COMMIT" style="text;html=1;align=center;fontSize=11;fontColor=#666666"
                vertex="1" parent="1">
          <mxGeometry x="990" y="106" width="100" height="14" as="geometry"/>
        </mxCell>

        <!-- Lane A label: Slot -->
        <mxCell id="laneAlbl" value="Slot at&#10;/users/2/INTENT&#10;(path-addressed,&#10;at most one entry)"
                style="text;html=1;fontSize=12;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="20" y="155" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Lane A: empty slot phase (before .627) -->
        <mxCell id="slotEmpty" value="empty&#10;(no in-flight writer)"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;fontColor=#666666"
                vertex="1" parent="1">
          <mxGeometry x="200" y="160" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- Lane A: T1 phase (.627 to .642) -->
        <mxCell id="slotT1" value="{ value: 2064, txn_id: T1, ACTIVE → COMMITTED at .628 }&#10;T1's bytes — the +64 credit's only on-disk record"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="380" y="160" width="350" height="40" as="geometry"/>
        </mxCell>

        <!-- Lane A: T2 phase (.642 onwards) -->
        <mxCell id="slotT2" value="{ value: 2048, txn_id: T2, ACTIVE → COMMITTED at .652 }&#10;T2's Put overwrites — T1's slot bytes are now gone"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="730" y="160" width="410" height="40" as="geometry"/>
        </mxCell>

        <!-- Overwrite arrow -->
        <mxCell id="overwriteArrow" style="endArrow=classic;html=1;strokeColor=#B85450;strokeWidth=2"
                edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="220" as="sourcePoint"/>
            <mxPoint x="730" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="overwriteLbl" value="overwrite"
                style="text;html=1;fontSize=11;fontStyle=1;fontColor=#B85450"
                vertex="1" parent="1">
          <mxGeometry x="735" y="222" width="80" height="14" as="geometry"/>
        </mxCell>

        <!-- Lane B label: Chain -->
        <mxCell id="laneBlbl" value="Chain at&#10;/users/2/&lt;ts&gt;&#10;(numeric versions,&#10;written at COMMIT&#10;or full-promote)"
                style="text;html=1;fontSize=12;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="20" y="285" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Chain: seed persists across the window -->
        <mxCell id="chainSeed" value="/users/2/&lt;seed_ts&gt; = 2000   (only numeric version that ever exists during this window)&#10;no /users/2/&lt;T1.commit_ts&gt; entry — pre-fix code never persists T1's value as a chain entry"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="160" y="290" width="980" height="40" as="geometry"/>
        </mxCell>

        <!-- Missing entry callout -->
        <mxCell id="missingEntry" value="missing entry&#10;/users/2/&lt;T1.commit_ts&gt;"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;dashed=1;fontSize=11;fontColor=#7A3434;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="430" y="350" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="missingArrow" style="endArrow=classic;html=1;strokeColor=#B85450;strokeWidth=1.5"
                edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="510" y="350" as="sourcePoint"/>
            <mxPoint x="510" y="332" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Lane C label: Reader -->
        <mxCell id="laneClbl" value="Reader&#10;(op 15)&#10;snapshot past&#10;T1.commit_ts"
                style="text;html=1;fontSize=12;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="20" y="445" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Reader scan box -->
        <mxCell id="readerScan" value="scan&#10;prefix /users/2/"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="850" y="440" width="100" height="46" as="geometry"/>
        </mxCell>

        <!-- What scan sees -->
        <mxCell id="seesPanel" value="What the scan sees, and how pre-fix code (commit 1a9635e) handles it:&#10;• numeric version /users/2/&lt;seed_ts&gt; = 2000  →  candidate at seed_ts&#10;• /users/2/INTENT (T2, ACTIVE)  →  resolver returns (false, 0) → skip the entry → no candidate from the slot"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=left;verticalAlign=top;spacingLeft=14;spacingTop=8"
                vertex="1" parent="1">
          <mxGeometry x="240" y="510" width="900" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow scan -> sees -->
        <mxCell id="scanToSees" style="endArrow=classic;html=1;strokeColor=#444444;strokeWidth=1.5"
                edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="900" y="486" as="sourcePoint"/>
            <mxPoint x="900" y="510" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Outcome callout -->
        <mxCell id="outcome" value="returns 2000&#10;T1's +64 credit lost"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontStyle=1;fontColor=#7A3434"
                vertex="1" parent="1">
          <mxGeometry x="970" y="438" width="170" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
