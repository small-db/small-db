<mxfile host="app.diagrams.net">
  <diagram name="Lost Intent" id="lost-intent">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Lost Intent: T2 overwrites the slot before T1's commit is recorded as a numeric version on the chain"
                style="text;html=1;align=center;fontSize=15;fontStyle=1"
                vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="From run 20260506T131345 — account 2 (Bob, partition users_us, owner america)"
                style="text;html=1;align=center;fontSize=12;fontColor=#666666"
                vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1100" height="20" as="geometry"/>
        </mxCell>

        <!-- Time axis -->
        <mxCell id="timeAxis" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#444444"
