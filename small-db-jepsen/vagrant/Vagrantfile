# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Define nodes with hostnames and IPs
  nodes = [
    { hostname: "asia", ip: "192.168.56.110" },
    { hostname: "europe", ip: "192.168.56.120" },
    { hostname: "america", ip: "192.168.56.130" }
  ]

  nodes.each do |node_config|
    config.vm.define node_config[:hostname] do |node|
      node.vm.box = "bento/ubuntu-24.04"

      node.vm.provider "virtualbox" do |vb|
        vb.memory = "4096"
        vb.cpus = 2
      end

      # use the default key: ~/.vagrant.d/insecure_private_key
      # 
      # ssh command: ssh -i ~/.vagrant.d/insecure_private_key vagrant@asia
      node.ssh.insert_key = false

      # set private ip
      node.vm.network "private_network", ip: node_config[:ip]

      # set hostname
      node.vm.hostname = node_config[:hostname]

      # set DNS entry
      node.vm.provision "shell", inline: <<-SHELL
        echo "#{nodes.map { |n| "#{n[:ip]} #{n[:hostname]}" }.join("\n")}" | sudo tee -a /etc/hosts
      SHELL

      # install necessary packages
      node.vm.provision "shell", inline: <<-SHELL
        # set "noninteractive" to avoid error:
        # dpkg-preconfigure: unable to re-open stdin: No such file or directory
        sudo DEBIAN_FRONTEND=noninteractive apt-get update

        # ifconfig
        sudo DEBIAN_FRONTEND=noninteractive apt-get install -y net-tools

        # psql
        sudo DEBIAN_FRONTEND=noninteractive apt-get install -y postgresql-client
      SHELL

      # set timezone to PST so its log's timestamp align with the host machine
      node.vm.provision "shell", inline: <<-SHELL
        sudo timedatectl set-timezone America/Los_Angeles
      SHELL

      # setup chrony for time synchronization
      node.vm.provision "shell", inline: <<-SHELL
        sudo DEBIAN_FRONTEND=noninteractive apt-get -y install chrony
      SHELL

      # Provision /opt/small-db as the persistent workdir for the server,
      # tools binary, dynamic libs, data, log, and pidfile. /tmp is wiped on
      # boot by systemd-tmpfiles (D /tmp), but /opt is not. After this, only
      # Jepsen's setup! (which empties this dir's contents) clears artifacts.
      node.vm.provision "shell", inline: <<-SHELL
        sudo mkdir -p /opt/small-db/lib
        sudo chown -R vagrant:vagrant /opt/small-db
      SHELL

      # Upload the clock_skew_server binary built on the host. Run a
      # debug build first (./scripts/setup/build.sh) so this file exists.
      # If the binary is missing, the file provisioner errors and the run
      # halts -- by design; we don't want a VM coming up without the
      # daemon the home-server TUI expects to find.
      clock_skew_bin =
        File.expand_path("../../../build/debug/src/clock_skew/clock_skew_server",
                         __FILE__)
      if File.exist?(clock_skew_bin)
        node.vm.provision "file", source: clock_skew_bin,
                                  destination: "/tmp/clock_skew_server"
        node.vm.provision "shell", inline: <<-SHELL
          sudo install -m 0755 /tmp/clock_skew_server /opt/small-db/clock_skew_server
          sudo tee /etc/systemd/system/clock-skew.service > /dev/null <<UNIT
[Unit]
Description=clock-skew probe daemon
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/opt/small-db/clock_skew_server --bind 0.0.0.0 --port 12321
Restart=always
RestartSec=2
User=vagrant

[Install]
WantedBy=multi-user.target
UNIT
          sudo systemctl daemon-reload
          sudo systemctl enable --now clock-skew.service
        SHELL
      else
        warn "clock_skew_server not built at #{clock_skew_bin}; " \
             "run ./scripts/setup/build.sh first, then `vagrant provision`."
      end
    end
  end
end
  